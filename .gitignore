# ============================================
# GTD API - Git Ignore
# ============================================

# Environment files
.env
.env.local
.env.*.local

# Keys & Secrets (sensitive credentials)
# Ignore all files under keys/ by default (private keys, certs, etc.)
keys/**
# Allow directory traversal so subfolders are visible to git
!keys/**/
# Whitelist: only public_key.pem is safe to track
!keys/**/public_key.pem

# Documentation (internal only)
docs/

# Frontend (separate deployment)
frontend/

# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go
*.test
*.out
go.work
go.work.sum
vendor/

# IDE
.idea/
.vscode/
.qodo/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Coverage
coverage.out
coverage.html

# Temporary files
tmp/
temp/
-p/
.claude/
