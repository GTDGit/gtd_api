# ============================================
# GTD API - Environment Configuration
# ============================================

# ============================================
# APPLICATION
# ============================================
PORT=8080
ENV=development
BASE_URL=https://api.gtd.co.id

# ============================================
# DATABASE (RDS over TLS)
# ============================================
# DB_HOST = RDS endpoint, DB_PORT = 5432, DB_USER = RDS master user.
DB_HOST=dev-postgres.ctwq6wii0ika.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_rds_password_here
DB_NAME=gtd
# DB_SSLMODE for RDS must require an encrypted, fully verified TLS connection.
# verify-full validates the RDS server certificate against the CA bundle in DB_SSLROOTCERT.
DB_SSLMODE=verify-full
# Path to the AWS RDS CA bundle mounted read-only into the container at /app/certs
# (docker-compose mounts the host ./certs directory as ./certs:/app/certs:ro).
DB_SSLROOTCERT=/app/certs/rds-global-bundle.pem

# ============================================
# REDIS
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_jwt_secret_here
CALLBACK_SECRET=your_callback_secret_for_hmac

# ============================================
# PPOB - DIGIFLAZZ
# ============================================
DIGIFLAZZ_USERNAME=your_username
DIGIFLAZZ_KEY_PRODUCTION=your_production_api_key
DIGIFLAZZ_KEY_DEVELOPMENT=your_development_api_key
DIGIFLAZZ_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# PPOB - KIOSBANK
# ============================================
KIOSBANK_BASE_URL=https://kiosbank-api-url
KIOSBANK_MERCHANT_ID=your_merchant_id
KIOSBANK_COUNTER_ID=your_counter_id
KIOSBANK_ACCOUNT_ID=your_account_id
KIOSBANK_MITRA=your_mitra
KIOSBANK_USERNAME=your_username
KIOSBANK_PASSWORD=your_password

# ============================================
# PPOB - ALTERRA
# ============================================
ALTERRA_BASE_URL=https://horven-api.sumpahpalapa.com/api
ALTERRA_CLIENT_ID=your_alterra_client_id
ALTERRA_PRIVATE_KEY_PATH=keys/alterra/private_key.pem
ALTERRA_PRIVATE_KEY_PEM=
ALTERRA_CALLBACK_PUBLIC_KEY=

# ============================================
# PAYMENT & DISBURSEMENT PROVIDERS
# Note: Same credentials used for VA Payment & Transfer
# ============================================

# --- Pakailink (VA: BCA, BSI, OCBC, CIMB, Permata, Muamalat, QRIS) ---
PAKAILINK_ENV=SANDBOX
PAKAILINK_BASE_URL=https://apigw-sandbox.pakailink.co.id
PAKAILINK_CLIENT_ID=your_pakailink_client_id
PAKAILINK_CLIENT_SECRET=your_pakailink_client_secret
PAKAILINK_PARTNER_ID=SANDBOX
PAKAILINK_CHANNEL_ID=
PAKAILINK_PRIVATE_KEY_PATH=keys/pakailink/private_key.pem
PAKAILINK_PRIVATE_KEY_PEM=
PAKAILINK_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/pakailink
PAKAILINK_QRIS_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/pakailink-qris

# --- Nobu (static QRIS acquiring; merchants onboarded via Excel form) ---
# Nobu has no register API. We issue Nobu a B2B token then verify its notify
# (HMAC-SHA512 with NOBU_CLIENT_SECRET). NOBU_PUBLIC_KEY_* verifies the token
# request signature (SHA256withRSA over "clientKey|timestamp").
NOBU_ENV=SANDBOX
NOBU_CLIENT_ID=your_nobu_client_id
NOBU_CLIENT_SECRET=your_nobu_client_secret
NOBU_PARTNER_ID=
NOBU_PUBLIC_KEY_PATH=keys/nobu/public_key.pem
NOBU_PUBLIC_KEY_PEM=
NOBU_CALLBACK_URL=https://api.gtd.co.id/nobu/v1.0/qr/qr-mpm-notify
# Outbound generate-QR client (api -> Nobu). After a merchant is activated we
# call qr-mpm-generate to obtain the static QR string; signing uses OUR private
# key (asymmetric token) + NOBU_CLIENT_SECRET (HMAC-SHA512). When NOBU_BASE_URL
# or the key is absent, activation falls back to manual qrisString paste.
NOBU_BASE_URL=
NOBU_PRIVATE_KEY_PATH=keys/nobu/private_key.pem
NOBU_PRIVATE_KEY_PEM=

# --- Internal service-to-service token (gateway → api QRIS proxy) ---
# Must match the gateway's INTERNAL_API_TOKEN.
INTERNAL_API_TOKEN=change_me_shared_internal_token

# --- BCA Direct (VA + Disbursement) ---
BCA_ENV=SANDBOX
BCA_CLIENT_ID=your_bca_client_id
BCA_CLIENT_SECRET=your_bca_client_secret
BCA_API_KEY=your_bca_api_key
BCA_API_SECRET=your_bca_api_secret
BCA_CORPORATE_ID=your_corporate_id
BCA_SOURCE_ACCOUNT=your_source_account
BCA_PRIVATE_KEY_PATH=keys/bca/private_key.pem
BCA_VA_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/bca
BCA_DISB_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/bca/disbursement

# --- BRI Direct (VA + Disbursement) ---
BRI_ENV=SANDBOX
BRI_BASE_URL=https://sandbox.partner.api.bri.co.id
BRI_CLIENT_ID=your_bri_client_id
BRI_CLIENT_SECRET=your_bri_client_secret
BRI_PARTNER_ID=22210
BRI_CHANNEL_ID=22210
BRI_BRIVA_NUMBER=22210
BRI_COMPANY_CODE=22210
BRI_SOURCE_ACCOUNT=your_source_account
BRI_PRIVATE_KEY_PATH=keys/bri/private_key.pem
BRI_VA_CALLBACK_URL=https://api.gtd.co.id/snap/v1.0/transfer-va/notify-payment-intrabank
BRI_DISB_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/bri/disbursement
BRI_CONNECTOR_CLIENT_KEY=
BRI_CONNECTOR_PUBLIC_KEY_PATH=
BRI_CONNECTOR_PUBLIC_KEY_PEM=
BRI_BRIZZI_USERNAME=your_brizzi_username
BRI_BRIZZI_DENOMINATIONS=20000,50000,100000,150000,200000

# --- BNI Direct (VA + Disbursement) ---
BNI_ENV=SANDBOX
BNI_CLIENT_ID=your_bni_client_id
BNI_CLIENT_SECRET=your_bni_client_secret
BNI_API_KEY=your_bni_api_key
BNI_API_SECRET=your_bni_api_secret
BNI_SOURCE_ACCOUNT=your_source_account
BNI_PRIVATE_KEY_PATH=keys/bni/private_key.pem
BNI_VA_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/bni
BNI_DISB_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/bni/disbursement

# --- Mandiri Direct (VA + Disbursement) ---
MANDIRI_ENV=SANDBOX
MANDIRI_CLIENT_ID=your_mandiri_client_id
MANDIRI_CLIENT_SECRET=your_mandiri_client_secret
MANDIRI_CORPORATE_ID=your_corporate_id
MANDIRI_COMPANY_CODE=your_company_code
MANDIRI_SOURCE_ACCOUNT=your_source_account
MANDIRI_PRIVATE_KEY_PATH=keys/mandiri/private_key.pem
MANDIRI_VA_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/mandiri
MANDIRI_DISB_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/mandiri/disbursement

# --- BNC Direct / Bank Neo (VA + Disbursement + BI-FAST) ---
BNC_ENV=SANDBOX
BNC_CLIENT_ID=your_bnc_client_id
BNC_CLIENT_SECRET=your_bnc_client_secret
BNC_PARTNER_ID=your_bnc_partner_id
BNC_CHANNEL_ID=your_channel_id
BNC_SOURCE_ACCOUNT=your_source_account
BNC_PRIVATE_KEY_PATH=keys/bnc/private_key.pem
BNC_CONNECTOR_CLIENT_KEY=
BNC_CONNECTOR_PUBLIC_KEY_PATH=
BNC_CONNECTOR_PUBLIC_KEY_PEM=
BNC_VA_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/bnc
BNC_DISB_CALLBACK_URL=https://api.gtd.co.id/bnc/v1.0/transfer/notify

# --- DANA Direct (E-Wallet, QRIS) ---
DANA_ENV=SANDBOX
DANA_BASE_URL=https://api.sandbox.dana.id
DANA_MERCHANT_ID=your_dana_merchant_id
DANA_CLIENT_ID=your_dana_client_id
DANA_CLIENT_SECRET=your_dana_client_secret
DANA_PARTNER_ID=SANDBOX
DANA_PRIVATE_KEY_PATH=keys/dana/private_key.pem
DANA_PRIVATE_KEY_PEM=
DANA_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/dana
DANA_RETURN_URL=https://app.gtd.co.id/payment/complete
# DANA as a disbursement/payout provider (reuses the DANA credentials above)
DANA_DISBURSEMENT_MERCHANT_PHONE=
DANA_DISBURSEMENT_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/dana-disbursement
# Fallback interbank fee (IDR) applied to bank payouts when the provider omits one
DISBURSEMENT_DEFAULT_BANK_FEE=2500

# --- OVO Direct (E-Wallet) ---
OVO_ENV=SANDBOX
OVO_APP_ID=your_ovo_app_id
OVO_API_KEY=your_ovo_api_key
OVO_MERCHANT_ID=your_ovo_merchant_id
OVO_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/ovo

# --- Midtrans (GoPay, ShopeePay) ---
MIDTRANS_ENV=SANDBOX
MIDTRANS_BASE_URL=
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxx
MIDTRANS_MERCHANT_ID=your_merchant_id
# Optional: override signature secret; defaults to MIDTRANS_SERVER_KEY.
MIDTRANS_WEBHOOK_SECRET=
MIDTRANS_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/midtrans

# --- Xendit (Retail: Indomaret, Alfamart) ---
XENDIT_ENV=SANDBOX
XENDIT_BASE_URL=https://api.xendit.co
XENDIT_API_KEY=xnd_development_xxxxx
XENDIT_API_VERSION=2024-11-11
XENDIT_CALLBACK_TOKEN=your_xendit_callback_token
XENDIT_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/xendit

# --- OVO Direct (E-wallet: OVO push-to-pay) ---
# Leave MERCHANT_ID/CLIENT_SECRET empty to disable OVO Direct; the payment
# selector then falls back to other OVO-capable providers (pakailink, dana, xendit).
OVO_ENV=SANDBOX
OVO_BASE_URL=https://api.ovo.id
OVO_MERCHANT_ID=
OVO_APP_ID=
OVO_CLIENT_SECRET=
OVO_API_KEY=
OVO_CALLBACK_URL=https://api.gtd.co.id/v1/webhook/ovo

# ============================================
# SCHEDULER INTERVALS
# ============================================
SYNC_INTERVAL=15m
RETRY_INTERVAL=10m
CALLBACK_RETRY_INTERVAL=1m
DIGIFLAZZ_CALLBACK_INTERVAL=30s

# Payment module workers
PAYMENT_STATUS_INTERVAL=10s
PAYMENT_STATUS_STALE_AFTER=30s
PAYMENT_EXPIRY_INTERVAL=1m
PAYMENT_CALLBACK_INTERVAL=30s

# ============================================
# QRIS STORAGE + BATCH/CALLBACK RUNTIME
# ============================================
# Object storage for QRIS merchant documents + rendered Nobu Excel batches.
# Driver "local" writes under STORAGE_LOCAL_PATH (dev stub); "s3" uploads to a
# private bucket. The same Storage interface backs both, so swapping is config-only.
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./data/qris-storage
S3_BUCKET=
S3_REGION=ap-southeast-3
S3_ENDPOINT=
S3_KEY_PREFIX=qris/
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are shared with the identity service.

# Nobu Excel batches: WIB slots (comma-separated HH:MM, in order; slot 1 = first).
# Mon-Fri only; weekend registrations roll into Monday's first batch. No pending
# registrations -> no file is rendered.
QRIS_BATCH_TIMES=10:00,15:00
QRIS_BATCH_TZ=Asia/Jakarta
# Retry tick for the qris_callbacks worker (client webhook delivery).
QRIS_CALLBACK_INTERVAL=30s
